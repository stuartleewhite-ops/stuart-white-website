---
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteNav from '../components/SiteNav.astro';
---
<BaseLayout
  title="New client intake — Stuart White"
  description="Bespoke fitness, nutrition and sleep coaching. Around 15 minutes. Your first seven days are free."
  bg="#0A0A0A"
>
  <Fragment slot="head">
    <style>
      :root {
        --bg-primary: #0A0A0A; --bg-secondary: #1A1A1A; --surface-light: #FFFFFF;
        --text-body: #e6e6e6; --text-muted: #c4c4c4; --text-low: #9a9a9a;
        --hairline: rgba(255,255,255,0.25); --hairline-focus: rgba(255,255,255,0.6);
        --error: #ff6b6b;
      }
      html, body { background: var(--bg-primary); color: var(--surface-light); line-height: 1.55; min-height: 100%; }
      body { padding-bottom: 120px; }
      .intake-shell { padding-top: 64px; }
      input, select, textarea, .tile, .checktile, .field { scroll-margin-top: 116px; }
      .progress-header { position: sticky; top: 64px; z-index: 900; background: var(--bg-primary); border-bottom: 1px solid var(--bg-secondary); }
      .progress-header-inner { max-width: 880px; margin: 0 auto; padding: 12px clamp(24px,5vw,52px); display: flex; justify-content: flex-end; }
      .progress-meta { font-size: 10px; font-weight: 500; letter-spacing: 0.12em; text-transform: uppercase; color: var(--text-muted); }
      .progress-track { height: 2px; background: var(--bg-secondary); width: 100%; }
      .progress-fill { height: 100%; background: var(--surface-light); width: 0%; transition: width 350ms ease-out; }
      .page { max-width: 720px; margin: 0 auto; padding: 48px 52px 64px; }
      .step { display: none; animation: fadeUp 0.4s ease-out both; }
      .step.active { display: block; }
      @keyframes fadeUp { from { opacity: 0; transform: translateY(12px); } to { opacity: 1; transform: translateY(0); } }
      @media (prefers-reduced-motion: reduce) { .step { animation: none; } }
      .corner-label { font-size: 10px; font-weight: 500; letter-spacing: 0.14em; text-transform: uppercase; color: var(--text-muted); display: block; margin-bottom: 18px; }
      h1.headline, h2.headline { font-family: 'Kensington Compressed', 'Arial Narrow', sans-serif; font-weight: 400; line-height: 0.98; font-size: clamp(40px, 5.5vw, 64px); color: var(--surface-light); margin-bottom: 18px; text-wrap: balance; }
      .lede { font-size: 15px; color: var(--text-body); line-height: 1.65; max-width: 520px; margin-bottom: 32px; }
      .lede p + p { margin-top: 14px; }
      .group { border-top: 1px solid var(--bg-secondary); padding-top: 28px; margin-top: 32px; }
      .group:first-of-type { border-top: none; padding-top: 0; margin-top: 0; }
      .group-label { font-size: 10px; font-weight: 600; letter-spacing: 0.14em; text-transform: uppercase; color: var(--text-muted); margin-bottom: 20px; display: block; }
      .group-hint { font-size: 13px; color: var(--text-low); margin-bottom: 22px; max-width: 520px; line-height: 1.6; }
      .row { display: grid; grid-template-columns: 1fr 1fr; gap: 24px; margin-bottom: 22px; }
      .row.one { grid-template-columns: 1fr; }
      .field { display: flex; flex-direction: column; gap: 8px; }
      .field-label { font-size: 11px; font-weight: 600; letter-spacing: 0.12em; text-transform: uppercase; color: var(--text-muted); }
      .field-hint { font-size: 13px; color: var(--text-low); line-height: 1.5; }
      .field-optional { font-size: 10px; letter-spacing: 0.1em; text-transform: uppercase; color: var(--text-low); margin-left: 8px; font-weight: 400; }
      input[type="text"], input[type="email"], input[type="tel"], input[type="date"], input[type="time"], input[type="number"], select, textarea {
        font-family: 'Montserrat', sans-serif; font-size: 15px; font-weight: 400; color: var(--surface-light);
        background: transparent; border: none; border-bottom: 1px solid var(--hairline);
        padding: 10px 0; outline: none; width: 100%; transition: border-color 150ms ease-out;
        border-radius: 0; -webkit-appearance: none; appearance: none;
      }
      input::placeholder, textarea::placeholder { color: var(--text-low); opacity: 1; }
      input:focus, select:focus, textarea:focus { border-bottom-color: var(--hairline-focus); }
      textarea { min-height: 110px; resize: vertical; line-height: 1.55; border: 1px solid var(--hairline); padding: 14px; border-radius: 2px; }
      textarea:focus { border-color: var(--hairline-focus); }
      select { background-image: linear-gradient(45deg, transparent 50%, #c4c4c4 50%), linear-gradient(135deg, #c4c4c4 50%, transparent 50%); background-position: calc(100% - 12px) 50%, calc(100% - 6px) 50%; background-size: 6px 6px, 6px 6px; background-repeat: no-repeat; padding-right: 28px; cursor: pointer; }
      select option { background: var(--bg-primary); color: var(--surface-light); }
      .tiles { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
      .tile { position: relative; display: block; border: 1px solid var(--hairline); padding: 14px 18px; cursor: pointer; font-size: 14px; color: var(--text-body); text-align: left; transition: all 120ms ease-out; border-radius: 2px; background: transparent; }
      .tile:hover { border-color: var(--hairline-focus); color: var(--surface-light); }
      .tile input { position: absolute; opacity: 0; pointer-events: none; }
      .tile.checked { background: var(--surface-light); color: var(--bg-primary); border-color: var(--surface-light); }
      .checkgrid { display: grid; grid-template-columns: repeat(auto-fit, minmax(160px, 1fr)); gap: 10px; }
      .checktile { position: relative; display: flex; align-items: center; gap: 12px; border: 1px solid var(--hairline); padding: 12px 14px; cursor: pointer; font-size: 14px; color: var(--text-body); transition: all 120ms ease-out; border-radius: 2px; }
      .checktile:hover { border-color: var(--hairline-focus); color: var(--surface-light); }
      .checktile input { position: absolute; opacity: 0; pointer-events: none; }
      .checktile .box { width: 14px; height: 14px; border: 1px solid var(--hairline); flex-shrink: 0; display: inline-flex; align-items: center; justify-content: center; transition: all 120ms ease-out; border-radius: 1px; }
      .checktile .box::after { content: ''; width: 6px; height: 6px; background: var(--bg-primary); opacity: 0; transition: opacity 120ms ease-out; }
      .checktile.checked { border-color: var(--surface-light); color: var(--surface-light); }
      .checktile.checked .box { background: var(--surface-light); border-color: var(--surface-light); }
      .checktile.checked .box::after { opacity: 1; }
      .slider-row { display: flex; align-items: center; gap: 18px; padding: 6px 0 4px; }
      .slider-row input[type="range"] { flex: 1; -webkit-appearance: none; appearance: none; background: transparent; height: 24px; margin: 0; }
      .slider-row input[type="range"]::-webkit-slider-runnable-track { height: 2px; background: var(--hairline); }
      .slider-row input[type="range"]::-moz-range-track { height: 2px; background: var(--hairline); }
      .slider-row input[type="range"]::-webkit-slider-thumb { -webkit-appearance: none; appearance: none; width: 18px; height: 18px; border-radius: 50%; background: var(--surface-light); border: none; margin-top: -8px; cursor: pointer; }
      .slider-row input[type="range"]::-moz-range-thumb { width: 18px; height: 18px; border-radius: 50%; background: var(--surface-light); border: none; cursor: pointer; }
      .slider-value { font-family: 'Kensington Compressed', 'Arial Narrow', sans-serif; font-size: 28px; line-height: 1; min-width: 36px; text-align: right; color: var(--surface-light); }
      .slider-ends { display: flex; justify-content: space-between; font-size: 11px; letter-spacing: 0.08em; text-transform: uppercase; color: var(--text-low); margin-top: 4px; }
      .followup { background: var(--bg-secondary); border-left: 2px solid var(--surface-light); padding: 24px; margin-top: 24px; display: none; }
      .followup.visible { display: block; }
      .followup .group { border-top: 1px solid #2a2a2a; }
      .followup .group:first-of-type { border-top: none; }
      .sig-canvas-wrap { background: var(--surface-light); border-radius: 2px; padding: 0; position: relative; }
      #signature-pad { display: block; width: 100%; height: 200px; touch-action: none; background: var(--surface-light); border-radius: 2px; }
      .sig-meta { display: flex; justify-content: space-between; align-items: center; margin-top: 10px; gap: 12px; flex-wrap: wrap; }
      .sig-help { font-size: 12px; color: var(--text-low); letter-spacing: 0.04em; }
      .btn-clear-sig { background: transparent; border: 1px solid var(--hairline); color: var(--text-body); font-family: 'Montserrat', sans-serif; font-size: 10px; letter-spacing: 0.12em; text-transform: uppercase; padding: 8px 14px; cursor: pointer; border-radius: 2px; }
      .btn-clear-sig:hover { border-color: var(--hairline-focus); color: var(--surface-light); }
      .agreement { background: var(--bg-secondary); padding: 28px; border-radius: 2px; max-height: 360px; overflow-y: auto; font-size: 13px; color: var(--text-body); line-height: 1.65; margin-bottom: 24px; }
      .agreement h4 { font-size: 13px; font-weight: 600; color: var(--surface-light); margin-top: 16px; margin-bottom: 8px; }
      .agreement h4:first-child { margin-top: 0; }
      .agreement p { margin-bottom: 10px; }
      .agreement strong { color: var(--surface-light); }
      .nav-row { display: flex; align-items: center; justify-content: space-between; gap: 24px; margin-top: 48px; padding-top: 32px; border-top: 1px solid var(--bg-secondary); }
      .btn { font-family: 'Montserrat', sans-serif; font-size: 11px; font-weight: 600; letter-spacing: 0.14em; text-transform: uppercase; padding: 16px 36px; cursor: pointer; border-radius: 2px; transition: all 150ms ease-out; white-space: nowrap; }
      .btn-primary { color: var(--bg-primary); background: var(--surface-light); border: 1px solid var(--surface-light); }
      .btn-primary:hover:not(:disabled) { background: #e6e6e6; }
      .btn-primary:disabled { opacity: 0.5; cursor: default; }
      .btn-ghost { color: var(--text-body); background: transparent; border: 1px solid var(--hairline); }
      .btn-ghost:hover { color: var(--surface-light); border-color: var(--hairline-focus); }
      .intro-points { list-style: none; padding: 0; margin: 28px 0; }
      .intro-points li { padding: 14px 0; border-bottom: 1px solid var(--bg-secondary); display: flex; gap: 18px; align-items: baseline; font-size: 14px; color: var(--text-body); }
      .intro-points li:last-child { border-bottom: none; }
      .intro-points .pt-label { font-size: 10px; font-weight: 600; letter-spacing: 0.14em; text-transform: uppercase; color: var(--text-muted); min-width: 80px; }
      .field.error input, .field.error select, .field.error textarea { border-color: var(--error); }
      .field.error .field-label { color: var(--error); }
      .form-error { color: var(--error); font-size: 13px; margin-top: 16px; display: none; }
      .form-error.visible { display: block; }
      .confirm-headline { font-family: 'Kensington Compressed', 'Arial Narrow', sans-serif; font-size: clamp(44px, 6vw, 72px); font-weight: 400; line-height: 1.0; margin-bottom: 20px; }
      .confirm-body p { margin-bottom: 14px; color: var(--text-body); font-size: 15px; line-height: 1.7; }
      .hp-field { position: absolute; left: -9999px; top: -9999px; }
      @media (max-width: 768px) {
        .page { padding: 32px 24px 48px; }
        .progress-header-inner { padding: 10px 24px; }
        .row { grid-template-columns: 1fr; gap: 18px; }
        h1.headline, h2.headline { font-size: clamp(36px, 10vw, 52px); }
        .checkgrid { grid-template-columns: 1fr 1fr; }
        .btn { padding: 14px 24px; }
        .nav-row { gap: 12px; }
      }
      @media (max-width: 420px) { .checkgrid { grid-template-columns: 1fr; } }
    </style>
  </Fragment>

  <SiteNav active="" />

  <div class="intake-shell">
    <div class="progress-header">
      <div class="progress-header-inner">
        <span class="progress-meta" id="progress-meta">New client intake</span>
      </div>
      <div class="progress-track"><div class="progress-fill" id="progress-fill"></div></div>
    </div>

    <div class="page">

      <section class="step active" data-step="intro">
        <span class="corner-label">Before you start</span>
        <h1 class="headline">New client intake.</h1>
        <div class="lede">
          <p>Around 15 minutes. Save and resume any time on the same device.</p>
          <p>I use what you share to build your bespoke fitness, nutrition and sleep plan. It lands in your app within five working days.</p>
          <p>The first seven days are free. After that it's £35 a week. Cancel any time.</p>
          <p>Be honest about anything that affects what's safe for you to do. The plan is only as good as the information you give me.</p>
        </div>
        <ul class="intro-points">
          <li><span class="pt-label">Time</span><span>Around 15 minutes</span></li>
          <li><span class="pt-label">Cost</span><span>£35 / week after 7-day free trial</span></li>
          <li><span class="pt-label">Plan</span><span>In your app within 5 working days</span></li>
          <li><span class="pt-label">Data</span><span>Handled in strict confidence</span></li>
        </ul>
        <div class="nav-row" style="justify-content: flex-end;">
          <button type="button" class="btn btn-primary" data-action="next">Start &rarr;</button>
        </div>
      </section>

      <form id="intake-form" name="intake" method="POST" data-netlify="true" netlify-honeypot="bot-field" action="/intake?success=1" autocomplete="on">
        <input type="hidden" name="form-name" value="intake" />
        <p class="hp-field"><label>Don't fill this out: <input name="bot-field" tabindex="-1" autocomplete="off" /></label></p>

        <section class="step" data-step="1">
          <span class="corner-label">Section 1 of 6 &middot; About you</span>
          <h2 class="headline">About you.</h2>
          <p class="lede">The basics. Two minutes.</p>
          <div class="group">
            <div class="row">
              <div class="field"><label class="field-label" for="f-name">Full name</label><input type="text" id="f-name" name="name" autocomplete="name" required /></div>
              <div class="field"><label class="field-label" for="f-email">Email</label><input type="email" id="f-email" name="email" autocomplete="email" required /></div>
            </div>
            <div class="row">
              <div class="field"><label class="field-label" for="f-phone">Phone <span class="field-optional">Optional</span></label><input type="tel" id="f-phone" name="phone" autocomplete="tel" /></div>
              <div class="field"><label class="field-label" for="f-dob">Date of birth</label><input type="date" id="f-dob" name="dob" required /></div>
            </div>
            <div class="row">
              <div class="field"><label class="field-label" for="f-gender">Gender</label>
                <select id="f-gender" name="gender" required><option value="">Select</option><option>Male</option><option>Female</option><option>Non-binary</option><option>Prefer not to say</option></select>
              </div>
              <div class="field"><label class="field-label" for="f-city">Town or city</label><input type="text" id="f-city" name="city" autocomplete="address-level2" required /></div>
            </div>
            <div class="row">
              <div class="field"><label class="field-label" for="f-height">Height (cm)</label><input type="number" id="f-height" name="height" min="120" max="230" step="1" required /></div>
              <div class="field"><label class="field-label" for="f-weight">Weight (kg)</label><input type="number" id="f-weight" name="weight" min="35" max="250" step="0.1" required /></div>
            </div>
          </div>
          <p class="form-error" id="err-1">Please fill in all required fields.</p>
          <div class="nav-row"><button type="button" class="btn btn-ghost" data-action="prev">&larr; Back</button><button type="button" class="btn btn-primary" data-action="next">Continue &rarr;</button></div>
        </section>

        <section class="step" data-step="2">
          <span class="corner-label">Section 2 of 6 &middot; Health screen</span>
          <h2 class="headline">Health screen.</h2>
          <p class="lede">A standard pre-exercise health check. All answers are confidential. If anything below is yes, a short follow-up appears at the end of the section.</p>
          <div class="group" id="parq-group">
            <div class="row one" style="margin-bottom:18px;"><div class="field"><label class="field-label">1. Has your doctor ever said that you have a heart condition, and that you should only do physical activity recommended by a doctor?</label><div class="tiles"><label class="tile"><input type="radio" name="parq1" value="No" /><span>No</span></label><label class="tile"><input type="radio" name="parq1" value="Yes" /><span>Yes</span></label></div></div></div>
            <div class="row one" style="margin-bottom:18px;"><div class="field"><label class="field-label">2. Do you feel pain in your chest when you do physical activity?</label><div class="tiles"><label class="tile"><input type="radio" name="parq2" value="No" /><span>No</span></label><label class="tile"><input type="radio" name="parq2" value="Yes" /><span>Yes</span></label></div></div></div>
            <div class="row one" style="margin-bottom:18px;"><div class="field"><label class="field-label">3. In the past month, have you had chest pain when you were not doing physical activity?</label><div class="tiles"><label class="tile"><input type="radio" name="parq3" value="No" /><span>No</span></label><label class="tile"><input type="radio" name="parq3" value="Yes" /><span>Yes</span></label></div></div></div>
            <div class="row one" style="margin-bottom:18px;"><div class="field"><label class="field-label">4. Do you lose your balance because of dizziness, or do you ever lose consciousness?</label><div class="tiles"><label class="tile"><input type="radio" name="parq4" value="No" /><span>No</span></label><label class="tile"><input type="radio" name="parq4" value="Yes" /><span>Yes</span></label></div></div></div>
            <div class="row one" style="margin-bottom:18px;"><div class="field"><label class="field-label">5. Do you have a bone or joint problem (for example, back, knee or hip) that could be made worse by a change in your physical activity?</label><div class="tiles"><label class="tile"><input type="radio" name="parq5" value="No" /><span>No</span></label><label class="tile"><input type="radio" name="parq5" value="Yes" /><span>Yes</span></label></div></div></div>
            <div class="row one" style="margin-bottom:18px;"><div class="field"><label class="field-label">6. Is your doctor currently prescribing drugs for your blood pressure or heart condition?</label><div class="tiles"><label class="tile"><input type="radio" name="parq6" value="No" /><span>No</span></label><label class="tile"><input type="radio" name="parq6" value="Yes" /><span>Yes</span></label></div></div></div>
            <div class="row one" style="margin-bottom:18px;"><div class="field"><label class="field-label">7. Do you know of any other reason why you should not do physical activity?</label><div class="tiles"><label class="tile"><input type="radio" name="parq7" value="No" /><span>No</span></label><label class="tile"><input type="radio" name="parq7" value="Yes" /><span>Yes</span></label></div></div></div>
            <div class="row one" style="margin-bottom:18px;"><div class="field"><label class="field-label">8. Are you currently pregnant or have you given birth in the last 12 months?</label><div class="tiles"><label class="tile"><input type="radio" name="parq8" value="No" /><span>No</span></label><label class="tile"><input type="radio" name="parq8" value="Yes" /><span>Yes</span></label></div></div></div>
          </div>
          <div class="followup" id="parq-followup">
            <span class="group-label">Follow-up</span>
            <p class="group-hint">You ticked yes to one or more of the questions above. A bit more detail helps me build a safe plan.</p>
            <div class="group">
              <div class="row one"><div class="field"><label class="field-label" for="f-gp">GP clearance status</label>
                <select id="f-gp" name="gpClearance"><option value="">Select</option><option>Clearance obtained, I have written confirmation</option><option>Clearance pending, I have contacted my GP</option><option>Not yet sought</option></select>
              </div></div>
              <div class="row one"><div class="field"><label class="field-label" for="f-preg">Currently pregnant or post-natal? <span class="field-optional">If applicable, include weeks</span></label><textarea id="f-preg" name="pregnancy"></textarea></div></div>
              <div class="row one"><div class="field"><label class="field-label" for="f-surg">Recent surgery or hospitalisation in last 12 months <span class="field-optional">If applicable</span></label><textarea id="f-surg" name="surgery"></textarea></div></div>
              <div class="row one"><div class="field"><label class="field-label" for="f-inj">Current or historical injuries relevant to training</label><textarea id="f-inj" name="injuries"></textarea></div></div>
              <div class="row one"><div class="field"><label class="field-label" for="f-med">Medications relevant to training</label><textarea id="f-med" name="medications"></textarea></div></div>
              <div class="row one"><div class="field"><label class="field-label" for="f-cond">Other medical conditions</label><textarea id="f-cond" name="conditions"></textarea></div></div>
            </div>
          </div>
          <p class="form-error" id="err-2">Please answer all eight screening questions.</p>
          <div class="nav-row"><button type="button" class="btn btn-ghost" data-action="prev">&larr; Back</button><button type="button" class="btn btn-primary" data-action="next">Continue &rarr;</button></div>
        </section>

        <section class="step" data-step="3">
          <span class="corner-label">Section 3 of 6 &middot; Goal and your week</span>
          <h2 class="headline">Your goal and your week.</h2>
          <p class="lede">What you want and how much room you've actually got for it.</p>
          <div class="group">
            <span class="group-label">Goal</span>
            <div class="row one"><div class="field"><label class="field-label" for="f-goal">Primary goal</label>
              <select id="f-goal" name="primaryGoal" required><option value="">Select the closest match</option><option>Lose body fat</option><option>Build muscle</option><option>Body recomposition (lose fat, build muscle simultaneously)</option><option>Improve general fitness and health</option><option>Improve sports performance</option><option>Improve health markers (blood pressure, cholesterol, blood sugar)</option></select>
            </div></div>
            <div class="row one"><div class="field"><label class="field-label" for="f-goal-words">Describe your goal in your own words</label><textarea id="f-goal-words" name="goalWords" required placeholder="What does success look like for you? Eight weeks, six months, a year from now."></textarea></div></div>
            <div class="row one"><div class="field"><label class="field-label" for="f-why-now">Why now? What's prompted this?</label><textarea id="f-why-now" name="whyNow" required placeholder="What changed, what's at stake, what made today the day you filled this in."></textarea></div></div>
            <div class="row one"><div class="field"><label class="field-label" for="f-deadline">Any specific event or deadline? <span class="field-optional">Optional</span></label><input type="text" id="f-deadline" name="deadline" placeholder="Wedding in October, race in March, board review in Q4..." /></div></div>
          </div>
          <div class="group">
            <span class="group-label">Time available</span>
            <div class="row">
              <div class="field"><label class="field-label" for="f-sessions">Sessions per week</label><select id="f-sessions" name="sessionsPerWeek" required><option value="">Select</option><option>2</option><option>3</option><option>4</option><option>5</option><option>6</option></select></div>
              <div class="field"><label class="field-label" for="f-session-len">Typical session length</label><select id="f-session-len" name="sessionLength" required><option value="">Select</option><option>30 minutes</option><option>45 minutes</option><option>60 minutes</option><option>75 minutes</option><option>90 minutes</option></select></div>
            </div>
          </div>
          <div class="group">
            <span class="group-label">Your week</span>
            <div class="row one"><div class="field"><label class="field-label" for="f-week">Describe a typical Monday to Friday for you</label>
              <p class="field-hint">Work hours, travel, family, when you'd ideally train. The more honest, the better the plan fits.</p>
              <textarea id="f-week" name="typicalWeek" required style="min-height:140px;"></textarea>
            </div></div>
          </div>
          <p class="form-error" id="err-3">Please complete all required fields in this section.</p>
          <div class="nav-row"><button type="button" class="btn btn-ghost" data-action="prev">&larr; Back</button><button type="button" class="btn btn-primary" data-action="next">Continue &rarr;</button></div>
        </section>

        <section class="step" data-step="4">
