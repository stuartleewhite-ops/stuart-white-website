    (function () {
      var STORAGE_KEY = 'sw-intake-v2';
      var STEP_ORDER = ['intro', '1', '2', '3', '4', '5', '6', 'done'];

      function $(s: string, ctx?: ParentNode) { return (ctx || document).querySelector(s); }
      function $$(s: string, ctx?: ParentNode) { return Array.from((ctx || document).querySelectorAll(s)); }

      var currentStep = 'intro';

      function showStep(stepId: string) {
        currentStep = stepId;
        $$('.step').forEach(function (s) { s.classList.remove('active'); });
        var el = document.querySelector('.step[data-step="' + stepId + '"]');
        if (el) el.classList.add('active');
        updateProgress();
        window.scrollTo({ top: 0, behavior: 'smooth' });
        save();
        if (stepId === '6' && sigPad) {
          requestAnimationFrame(function () { sigPad.resize(); });
        }
      }

      function updateProgress() {
        var idx = STEP_ORDER.indexOf(currentStep);
        var total = STEP_ORDER.length - 2;
        var meta = $('#progress-meta') as HTMLElement;
        var fill = $('#progress-fill') as HTMLElement;
        if (currentStep === 'intro') { meta.textContent = 'New client intake'; fill.style.width = '0%'; }
        else if (currentStep === 'done') { meta.textContent = 'Submitted'; fill.style.width = '100%'; }
        else { meta.textContent = 'Section ' + currentStep + ' of 6'; fill.style.width = (Math.max(0, idx - 1) / total * 100) + '%'; }
      }

      function refreshParqFollowup() {
        var anyYes = false;
        for (var i = 1; i <= 8; i++) {
          var checked = document.querySelector('input[name="parq' + i + '"]:checked') as HTMLInputElement | null;
          if (checked && checked.value === 'Yes') { anyYes = true; break; }
        }
        var el = $('#parq-followup');
        if (el) el.classList.toggle('visible', anyYes);
      }

      function getFormState() {
        var state: Record<string, any> = { step: currentStep };
        $$('input[type="text"], input[type="email"], input[type="tel"], input[type="date"], input[type="time"], input[type="number"], input[type="range"], input[type="hidden"], select, textarea').forEach(function (el: any) {
          if (el.id) state[el.id] = el.value;
        });
        var radioNames: Record<string, boolean> = {};
        $$('input[type="radio"]').forEach(function (el: any) { if (el.name) radioNames[el.name] = true; });
        Object.keys(radioNames).forEach(function (name) {
          var checked = document.querySelector('input[name="' + name + '"]:checked') as HTMLInputElement | null;
          state['__r_' + name] = checked ? checked.value : '';
        });
        var cbNames: Record<string, boolean> = {};
        $$('input[type="checkbox"]').forEach(function (el: any) { if (el.name) cbNames[el.name] = true; });
        Object.keys(cbNames).forEach(function (name) {
          var values = $$('input[name="' + name + '"]:checked').map(function (el: any) { return el.value; });
          state['__c_' + name] = values;
        });
        if (sigPad && !sigPad.isEmpty()) {
          state['__sig'] = sigPad.toDataURL();
        }
        return state;
      }

      function setFormState(state: Record<string, any>) {
        if (!state) return;
        Object.keys(state).forEach(function (key) {
          if (key === 'step' || key.indexOf('__') === 0) return;
          var el = document.getElementById(key) as HTMLInputElement | null;
          if (el) el.value = state[key];
          if (el && el.id === 'f-cardio') ($('#f-cardio-val') as HTMLElement).textContent = state[key];
          if (el && el.id === 'f-stress') ($('#f-stress-val') as HTMLElement).textContent = state[key];
        });
        Object.keys(state).forEach(function (key) {
          if (key.indexOf('__r_') === 0) {
            var name = key.slice(4);
            var val = state[key];
            if (val) {
              var radio = document.querySelector('input[name="' + name + '"][value="' + val + '"]') as HTMLInputElement | null;
              if (radio) { radio.checked = true; syncTileVisual(radio); }
            }
          }
          if (key.indexOf('__c_') === 0) {
            var name2 = key.slice(4);
            (state[key] || []).forEach(function (v: string) {
              var escaped = (window.CSS && CSS.escape) ? CSS.escape(v) : v;
              var cb = document.querySelector('input[name="' + name2 + '"][value="' + escaped + '"]') as HTMLInputElement | null;
              if (cb) { cb.checked = true; syncCheckVisual(cb); }
            });
          }
          if (key === '__sig' && state[key]) { pendingSigData = state[key]; }
        });
        refreshParqFollowup();
      }

      function save() {
        try { localStorage.setItem(STORAGE_KEY, JSON.stringify(getFormState())); } catch (e) { }
      }

      function restore() {
        try {
          var raw = localStorage.getItem(STORAGE_KEY);
          if (raw) {
            var state = JSON.parse(raw);
            setFormState(state);
            if (state.step && state.step !== 'done') currentStep = state.step;
          }
        } catch (e) { }
      }

      function syncTileVisual(radio: HTMLInputElement) {
        var name = radio.name;
        $$('input[type="radio"][name="' + name + '"]').forEach(function (r: any) {
          var tile = r.closest('.tile');
          if (tile) tile.classList.toggle('checked', r.checked);
        });
      }
      function syncCheckVisual(cb: HTMLInputElement) {
        var tile = cb.closest('.checktile');
        if (tile) tile.classList.toggle('checked', cb.checked);
      }

      function validateStep(step: string) {
        var stepEl = document.querySelector('.step[data-step="' + step + '"]');
        if (!stepEl) return true;
        var ok = true;
        $$('.field.error', stepEl).forEach(function (f) { f.classList.remove('error'); });
        $$('input[required], select[required], textarea[required]', stepEl).forEach(function (el: any) {
          var missing = false;
          if (el.type === 'checkbox') { if (!el.checked) missing = true; }
          else { if (!el.value) missing = true; }
          if (missing) {
            var fieldWrap = el.closest('.field');
            if (fieldWrap) fieldWrap.classList.add('error');
            ok = false;
          }
        });
        if (step === '2') {
          for (var i = 1; i <= 8; i++) {
            var any = document.querySelector('input[name="parq' + i + '"]:checked');
            if (!any) { ok = false; break; }
          }
        }
        if (step === '5') {
          if (!document.querySelector('input[name="caffeineAfter2"]:checked')) ok = false;
          for (var j = 1; j <= 8; j++) {
            var anyD = document.querySelector('input[name="diet' + j + '"]:checked');
            if (!anyD) { ok = false; break; }
          }
        }
        if (step === '6') {
          if (!($('#f-agree') as HTMLInputElement).checked) ok = false;
          if (!sigPad || sigPad.isEmpty()) ok = false;
        }
        var err = document.getElementById('err-' + step);
        if (err) err.classList.toggle('visible', !ok);
        return ok;
      }

      // ---- Signature pad ----
      var sigPad: any, sigHasInk = false, pendingSigData: string | null = null;

      function SignaturePad(this: any, canvas: HTMLCanvasElement) {
        this.canvas = canvas;
        this.ctx = canvas.getContext('2d');
        this.drawing = false;
        this.last = null;
        this._bind();
        var self = this;
        window.addEventListener('resize', function () { self.resize(); });
      }
      SignaturePad.prototype.resize = function (this: any) {
        var ratio = Math.max(window.devicePixelRatio || 1, 1);
        var w = this.canvas.offsetWidth;
        if (w === 0) return;
        var h = 200;
        var existing = sigHasInk ? this.canvas.toDataURL() : null;
        this.canvas.width = w * ratio;
        this.canvas.height = h * ratio;
        this.canvas.style.height = h + 'px';
        this.ctx.setTransform(1, 0, 0, 1, 0, 0);
        this.ctx.scale(ratio, ratio);
        this.ctx.lineCap = 'round';
        this.ctx.lineJoin = 'round';
        this.ctx.lineWidth = 2;
        this.ctx.strokeStyle = '#0A0A0A';
        this.ctx.fillStyle = '#FFFFFF';
        this.ctx.fillRect(0, 0, w, h);
        var self = this;
        if (existing) {
          var img = new Image();
          img.onload = function () { self.ctx.drawImage(img, 0, 0, w, h); sigHasInk = true; };
          img.src = existing;
        } else if (pendingSigData) {
          var img2 = new Image();
          img2.onload = function () { self.ctx.drawImage(img2, 0, 0, w, h); sigHasInk = true; pendingSigData = null; };
          img2.src = pendingSigData;
        } else {
          sigHasInk = false;
        }
      };
      SignaturePad.prototype._point = function (this: any, e: any) {
        var rect = this.canvas.getBoundingClientRect();
        var t = e.touches && e.touches[0] ? e.touches[0] : (e.changedTouches && e.changedTouches[0] ? e.changedTouches[0] : e);
        return { x: t.clientX - rect.left, y: t.clientY - rect.top };
      };
      SignaturePad.prototype._bind = function (this: any) {
        var self = this;
        function start(e: any) { e.preventDefault(); self.drawing = true; self.last = self._point(e); sigHasInk = true; }
        function move(e: any) {
          if (!self.drawing) return;
          e.preventDefault();
          var p = self._point(e);
          self.ctx.beginPath();
          self.ctx.moveTo(self.last.x, self.last.y);
          self.ctx.lineTo(p.x, p.y);
          self.ctx.stroke();
          self.last = p;
        }
        function end() { if (self.drawing) { self.drawing = false; save(); } }
        this.canvas.addEventListener('mousedown', start);
        this.canvas.addEventListener('mousemove', move);
        this.canvas.addEventListener('mouseup', end);
        this.canvas.addEventListener('mouseleave', end);
        this.canvas.addEventListener('touchstart', start, { passive: false });
        this.canvas.addEventListener('touchmove', move, { passive: false });
        this.canvas.addEventListener('touchend', end);
        this.canvas.addEventListener('touchcancel', end);
      };
      SignaturePad.prototype.clear = function (this: any) {
        this.ctx.fillStyle = '#FFFFFF';
        this.ctx.fillRect(0, 0, this.canvas.width, this.canvas.height);
        sigHasInk = false;
      };
      SignaturePad.prototype.isEmpty = function () { return !sigHasInk; };
      SignaturePad.prototype.toDataURL = function (this: any) { return this.canvas.toDataURL('image/png'); };

      function initSignature() {
        var sigCanvas = $('#signature-pad') as HTMLCanvasElement;
        sigPad = new (SignaturePad as any)(sigCanvas);
        var clearBtn = $('#clear-sig');
        if (clearBtn) clearBtn.addEventListener('click', function () {
          sigPad.clear();
          ($('#f-sig-data') as HTMLInputElement).value = '';
          save();
        });
      }

      // ---- Submit to Netlify Forms ----
      function encodeFormData(form: HTMLFormElement) {
        var fd = new FormData(form);
        var pairs: string[] = [];
        fd.forEach(function (value, key) {
          pairs.push(encodeURIComponent(key) + '=' + encodeURIComponent(value as string));
        });
        return pairs.join('&');
      }

      function handleSubmit(e: Event) {
        e.preventDefault();
        if (!validateStep('6')) return;
        var btn = $('#btn-submit') as HTMLButtonElement;
        btn.disabled = true;
        btn.textContent = 'Submitting...';
        if (sigPad && !sigPad.isEmpty()) {
          ($('#f-sig-data') as HTMLInputElement).value = sigPad.toDataURL();
        }
        var form = $('#intake-form') as HTMLFormElement;
        var body = encodeFormData(form);
        fetch('/', {
          method: 'POST',
          headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
          body: body,
        })
          .then(function (r) { if (!r.ok) throw new Error('Server ' + r.status); onSubmitSuccess(); })
          .catch(function (err) { console.error('Submit error', err); onSubmitError(); });
      }

      function onSubmitSuccess() {
        try { localStorage.removeItem(STORAGE_KEY); } catch (e) { }
        showStep('done');
      }
      function onSubmitError() {
        var btn = $('#btn-submit') as HTMLButtonElement;
        btn.disabled = false;
        btn.textContent = 'Submit form';
        var err = $('#err-6') as HTMLElement;
        err.textContent = 'Could not submit. Please try again, or email hello@stuart-white.co.uk.';
        err.classList.add('visible');
      }

      function bind() {
        $$('button[data-action]').forEach(function (btn) {
          btn.addEventListener('click', function () {
            var action = btn.getAttribute('data-action');
            if (action === 'next') {
              if (currentStep === 'intro') { showStep('1'); return; }
              if (!validateStep(currentStep)) return;
              var idx = STEP_ORDER.indexOf(currentStep);
              if (idx < STEP_ORDER.length - 1) showStep(STEP_ORDER[idx + 1]);
            } else if (action === 'prev') {
              var i = STEP_ORDER.indexOf(currentStep);
              if (i > 0) showStep(STEP_ORDER[i - 1]);
            }
          });
        });
        var form = $('#intake-form');
        if (form) form.addEventListener('submit', handleSubmit);
        document.addEventListener('input', function (e) {
          var target = e.target as HTMLElement;
          if (target.matches('input, select, textarea')) {
            if (target.id === 'f-cardio') ($('#f-cardio-val') as HTMLElement).textContent = (target as HTMLInputElement).value;
            if (target.id === 'f-stress') ($('#f-stress-val') as HTMLElement).textContent = (target as HTMLInputElement).value;
            save();
          }
        });
        document.addEventListener('change', function (e) {
          var target = e.target as HTMLInputElement;
          if (target.matches('input[type="radio"]')) {
            syncTileVisual(target);
            if (target.name && target.name.indexOf('parq') === 0) refreshParqFollowup();
          }
          if (target.matches('input[type="checkbox"]')) {
            syncCheckVisual(target);
          }
          save();
        });
        var today = new Date().toISOString().slice(0, 10);
        var dEl = $('#f-date') as HTMLInputElement;
        if (dEl && !dEl.value) dEl.value = today;
      }

      function init() {
        bind();
        initSignature();
        restore();
        showStep(currentStep);
      }

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', init);
      } else {
        init();
      }
    })();
  </script>
</BaseLayout>
