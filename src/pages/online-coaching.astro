---
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteNav from '../components/SiteNav.astro';
import SiteFooter from '../components/SiteFooter.astro';
import { INTAKE_URL } from '../lib/site-config';

const tools = [
  { icon: '/images/icons/01-bespoke-plan.svg', text: 'Bespoke fitness, nutrition and sleep plan, unique to you and your goals.' },
  { icon: '/images/icons/02-coaching-app.svg', text: 'Coaching app to log every session, track your weights and see progress over time.' },
  { icon: '/images/icons/03-nutrition.svg', text: 'Simple, effective nutrition plan, personalised to you. No complicated recipes.' },
  { icon: '/images/icons/04-flexible-plan.svg', text: 'Unlimited programme adjustments. The plan flexes around you and your life.' },
  { icon: '/images/icons/05-coach-support.svg', text: 'Direct coach support and feedback. Daily check-ins to keep you accountable.' },
];

const inclusions = [
  'Bespoke fitness and nutrition plan',
  'Practical sleep habit changes',
  'App access to log results and track performance',
  'Direct coach support and feedback',
  'Programme adjustments as you progress',
  '1:1 calls whenever you need them',
];

const steps = [
  { num: '01', title: 'Start free trial', desc: 'Add your card and start. The first seven days are free.' },
  { num: '02', title: 'Intake form', desc: 'A short form about your life, schedule, food and goals.' },
  { num: '03', title: 'Programme build', desc: 'I build your bespoke plan and load it into the app within 48 hours.' },
  { num: '04', title: 'Go live', desc: 'Each day you train, log results and we track performance together.' },
];
---
<BaseLayout
  title="Online coaching — Stuart White"
  description="Fitness, nutrition and sleep coaching delivered remotely, built around your life. £35 a week, first week free, no contract. Works anywhere in the UK and beyond."
  bg="#0A0A0A"
>
  <Fragment slot="head">
    <style>
      .oc-btn-light:hover { background: #FFFFFF; }
      .oc-btn-dark:hover { background: #1A1A1A; }
      .oc-textlink:hover { border-color: currentColor !important; }
      @media (max-width: 900px) {
        [data-two] { grid-template-columns: 1fr !important; }
        [data-tools] { grid-template-columns: 1fr 1fr !important; }
        [data-steps] { grid-template-columns: 1fr !important; }
        [data-price] { grid-template-columns: 1fr !important; }
      }
      @media (max-width: 560px) { [data-tools] { grid-template-columns: 1fr !important; } }
    </style>
  </Fragment>

  <div style="font-family:'Montserrat',sans-serif;background:#FFFFFF;color:#0A0A0A;">
    <SiteNav active="/online-coaching" />

    <!-- HERO -->
    <section style="position:relative;min-height:92svh;display:flex;flex-direction:column;justify-content:flex-end;padding:0 clamp(24px,6vw,80px) clamp(56px,8vh,100px);overflow:hidden;background:#0A0A0A;">
      <img src="/images/raw/squat-1.jpg" alt="An athlete lifting a barbell, captured with motion blur" style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;object-position:60% center;filter:grayscale(1) contrast(1.08) brightness(0.9);z-index:0;" fetchpriority="high" />
      <div aria-hidden="true" style="position:absolute;inset:0;z-index:1;background:linear-gradient(90deg,rgba(10,10,10,0.92) 0%,rgba(10,10,10,0.6) 45%,rgba(10,10,10,0.15) 100%);"></div>
      <div aria-hidden="true" style="position:absolute;left:0;right:0;bottom:0;height:220px;z-index:1;background:linear-gradient(to top,rgba(10,10,10,0.9),transparent);"></div>
      <div style="position:relative;z-index:2;max-width:740px;color:#FFFFFF;">
        <span style="display:block;font-size:11px;font-weight:600;letter-spacing:0.18em;text-transform:uppercase;color:#9A9A9A;margin-bottom:22px;">Online coaching</span>
        <h1 style="font-family:'Kensington Compressed','Arial Narrow',sans-serif;font-weight:400;font-size:clamp(48px,8vw,96px);line-height:0.95;margin:0 0 22px;">Build a fitter, stronger, healthier you in 90 days.</h1>
        <p style="font-size:clamp(16px,1.5vw,18px);line-height:1.55;color:#E6E6E6;max-width:520px;margin:0 0 20px;">Your body responds to how you train, eat and sleep. The hard part is making it work around a schedule that doesn't leave much room. That's what I do, wherever you are, for £35 a week.</p>
        <p style="font-size:13px;color:#9A9A9A;margin:0 0 34px;">First week free · No contract · Cancel any time</p>
        <a href={INTAKE_URL} class="oc-btn-light" style="display:inline-block;background:#FFFFFF;color:#0A0A0A;border:1px solid #FFFFFF;font-size:12px;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;padding:16px 40px;border-radius:2px;transition:background .15s;">Start free trial</a>
      </div>
    </section>

    <!-- BUILT AROUND YOUR LIFE -->
    <section style="padding:clamp(64px,9vw,116px) clamp(24px,6vw,80px);">
      <div style="max-width:1180px;margin:0 auto;">
        <span style="display:block;font-size:11px;font-weight:600;letter-spacing:0.16em;text-transform:uppercase;color:#6B6B6B;margin-bottom:32px;">The approach</span>
        <div data-two style="display:grid;grid-template-columns:1fr 1fr;gap:clamp(32px,5vw,72px);align-items:start;">
          <h2 style="font-family:'Kensington Compressed','Arial Narrow',sans-serif;font-weight:400;font-size:clamp(34px,4.5vw,58px);line-height:0.98;margin:0;">Built around your life, not a template.</h2>
          <div>
            <p style="font-size:17px;line-height:1.6;color:#333333;margin:0 0 18px;">You want to be in better shape but your life is busy and prioritising yourself is hard. That's where I come in. I build a plan that's unique to you; your schedule, your travel, your food environment. So it sticks.</p>
            <p style="font-size:17px;line-height:1.6;color:#333333;margin:0;">This isn't an eight-week project. It's a permanent upgrade to how you operate.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ONE COACH (dark) -->
    <section style="background:#0A0A0A;color:#FFFFFF;padding:clamp(64px,9vw,116px) clamp(24px,6vw,80px);">
      <div style="max-width:1180px;margin:0 auto;">
        <span style="display:block;font-size:11px;font-weight:600;letter-spacing:0.16em;text-transform:uppercase;color:#9A9A9A;margin-bottom:32px;">One point of contact</span>
        <div data-two style="display:grid;grid-template-columns:1fr 1fr;gap:clamp(32px,5vw,72px);align-items:center;">
          <img src="/images/raw/laptop-2.jpg" alt="Working at a laptop, motion-blurred" style="width:100%;aspect-ratio:4/3;object-fit:cover;filter:grayscale(1) contrast(1.05);display:block;" loading="lazy" />
          <div>
            <h2 style="font-family:'Kensington Compressed','Arial Narrow',sans-serif;font-weight:400;font-size:clamp(34px,4.5vw,56px);line-height:0.98;margin:0 0 22px;">One coach covering all your needs.</h2>
            <p style="font-size:17px;line-height:1.6;color:#CCCCCC;margin:0;max-width:480px;">Think of me as your personal trainer, nutritionist, sleep coach and life coach combined. One simple programme, custom-made for you. With someone in your corner daily to keep it on track when things get messy.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- EVERYTHING YOU NEED -->
    <section style="padding:clamp(64px,9vw,116px) clamp(24px,6vw,80px);">
      <div style="max-width:1180px;margin:0 auto;">
        <span style="display:block;font-size:11px;font-weight:600;letter-spacing:0.16em;text-transform:uppercase;color:#6B6B6B;margin-bottom:20px;">What's included</span>
        <h2 style="font-family:'Kensington Compressed','Arial Narrow',sans-serif;font-weight:400;font-size:clamp(34px,5vw,60px);line-height:1;margin:0 0 52px;max-width:640px;">Everything you need, nothing you don't.</h2>
        <ul data-tools style="list-style:none;margin:0;padding:0;display:grid;grid-template-columns:repeat(5,1fr);gap:clamp(24px,3vw,40px);">
          {tools.map((t) => (
            <li style="display:flex;flex-direction:column;gap:18px;">
              <img src={t.icon} alt="" aria-hidden="true" style="width:44px;height:44px;display:block;" />
              <p style="font-size:14px;line-height:1.6;color:#333333;margin:0;">{t.text}</p>
            </li>
          ))}
        </ul>
      </div>
    </section>

    <!-- TESTIMONIAL (dark) -->
    <section style="background:#0A0A0A;color:#FFFFFF;padding:clamp(72px,10vw,120px) clamp(24px,6vw,80px);text-align:center;">
      <div style="max-width:880px;margin:0 auto;">
        <blockquote style="font-family:'Kensington Compressed','Arial Narrow',sans-serif;font-weight:400;font-size:clamp(28px,4vw,50px);line-height:1.14;margin:0;">&ldquo;I feel amazing, I've lost 8 kgs so far and I'm enjoying training so much. You can tell Stu really cares about my progress.&rdquo;</blockquote>
        <p style="font-size:14px;color:#9A9A9A;margin:26px 0 0;font-style:italic;">Emily</p>
      </div>
    </section>

    <!-- PRICING -->
    <section style="padding:clamp(64px,9vw,116px) clamp(24px,6vw,80px);">
      <div style="max-width:1180px;margin:0 auto;">
        <span style="display:block;font-size:11px;font-weight:600;letter-spacing:0.16em;text-transform:uppercase;color:#6B6B6B;margin-bottom:20px;">Pricing</span>
        <h2 style="font-family:'Kensington Compressed','Arial Narrow',sans-serif;font-weight:400;font-size:clamp(34px,5vw,60px);line-height:1;margin:0 0 14px;max-width:680px;">Simple pricing and no long-term contract.</h2>
        <p style="font-size:17px;line-height:1.55;color:#6B6B6B;max-width:520px;margin:0 0 48px;">Start with a seven-day free trial. Then pay weekly, so there's no long-term contract and no big payment upfront.</p>
        <div data-price style="display:grid;grid-template-columns:0.9fr 1.1fr;border:1px solid #0A0A0A;">
          <div style="padding:clamp(32px,4vw,52px);border-right:1px solid #E6E6E6;">
            <span style="font-size:11px;font-weight:600;letter-spacing:0.14em;text-transform:uppercase;color:#6B6B6B;">Coaching plan</span>
            <div style="display:flex;align-items:baseline;gap:8px;margin:16px 0 4px;"><span style="font-family:'Kensington Compressed','Arial Narrow',sans-serif;font-size:clamp(64px,7vw,88px);line-height:0.95;">£35</span><span style="font-size:14px;color:#6B6B6B;">per week</span></div>
            <p style="font-size:12px;color:#6B6B6B;margin:0 0 32px;">After your seven-day free trial. Cancel any time.</p>
            <ul style="list-style:none;margin:0 0 36px;padding:0;display:flex;flex-direction:column;gap:14px;">
              {inclusions.map((f) => (
                <li style="display:flex;gap:12px;font-size:14px;line-height:1.5;color:#333333;"><span aria-hidden="true" style="color:#0A0A0A;">·</span><span>{f}</span></li>
              ))}
            </ul>
            <a href={INTAKE_URL} class="oc-btn-dark" style="display:block;text-align:center;background:#0A0A0A;color:#FFFFFF;border:1px solid #0A0A0A;font-size:12px;font-weight:600;letter-spacing:0.1em;text-transform:uppercase;padding:16px 20px;border-radius:2px;transition:background .15s;">Start free trial</a>
          </div>
          <div style="display:flex;align-items:center;justify-content:center;padding:clamp(32px,4vw,52px);">
            <picture>
              <source srcset="/images/coaching-app-phone-briefs.webp" type="image/webp" />
              <img src="/images/coaching-app-phone-briefs.png" alt="The coaching app on a phone alongside a client's welcome pack and nutrition plan" style="max-width:min(440px,100%);width:100%;height:auto;display:block;" loading="lazy" />
            </picture>
          </div>
        </div>
      </div>
    </section>

    <!-- HOW IT WORKS (dark) -->
    <section style="background:#0A0A0A;color:#FFFFFF;padding:clamp(64px,9vw,116px) clamp(24px,6vw,80px);">
      <div style="max-width:1180px;margin:0 auto;">
        <span style="display:block;font-size:11px;font-weight:600;letter-spacing:0.16em;text-transform:uppercase;color:#9A9A9A;margin-bottom:20px;">How it works</span>
        <h2 style="font-family:'Kensington Compressed','Arial Narrow',sans-serif;font-weight:400;font-size:clamp(34px,5vw,60px);line-height:1;margin:0 0 52px;max-width:560px;">Four steps from here to live.</h2>
        <div data-steps style="display:grid;grid-template-columns:repeat(4,1fr);gap:1px;background:#2A2A2A;border:1px solid #2A2A2A;">
          {steps.map((st) => (
            <div style="background:#0A0A0A;padding:clamp(24px,2.5vw,34px);display:flex;flex-direction:column;gap:14px;">
              <span style="font-family:'Kensington Compressed','Arial Narrow',sans-serif;font-size:40px;line-height:1;color:#6B6B6B;">{st.num}</span>
              <h3 style="font-size:18px;font-weight:600;margin:0;color:#FFFFFF;">{st.title}</h3>
              <p style="font-size:14px;line-height:1.6;color:#9A9A9A;margin:0;">{st.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- CLOSING CTA -->
    <section style="background:#FFFFFF;color:#0A0A0A;padding:clamp(72px,10vw,128px) clamp(24px,6vw,80px);text-align:center;">
      <div style="max-width:760px;margin:0 auto;">
        <h2 style="font-family:'Kensington Compressed','Arial Narrow',sans-serif;font-weight:400;font-size:clamp(36px,5.5vw,68px);line-height:0.98;margin:0 0 22px;">Ready for a fitter, stronger, healthier you in 90 days?</h2>
        <p style="font-size:17px;line-height:1.6;color:#6B6B6B;max-width:520px;margin:0 auto 20px;">Work with someone who gets your schedule, your pressure and your goals. Who's in your corner every day, and who truly cares about your progress.</p>
        <p style="font-size:13px;color:#9A9A9A;margin:0 0 36px;">£35 a week · First week free · Cancel any time</p>
        <a href={INTAKE_URL} class="oc-btn-dark" style="display:inline-block;background:#0A0A0A;color:#FFFFFF;border:1px solid #0A0A0A;font-size:12px;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;padding:16px 44px;border-radius:2px;transition:background .15s;">Start free trial</a>
        <p style="font-size:14px;color:#6B6B6B;margin:32px 0 0;">Not sure it's the right fit? <a href="/book-a-call" class="oc-textlink" style="color:#0A0A0A;font-weight:600;border-bottom:1px solid #CCCCCC;transition:border-color .15s;">Book a free 15-minute call</a></p>
      </div>
    </section>

    <SiteFooter />
  </div>
</BaseLayout>
