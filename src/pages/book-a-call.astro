---
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteNav from '../components/SiteNav.astro';
import SiteFooter from '../components/SiteFooter.astro';
import CalendlyEmbed from '../components/CalendlyEmbed.astro';
import { CALENDLY } from '../lib/site-config';
---
<BaseLayout
  title="Book a free 15-minute call — Stuart White"
  description="A free 15-minute video call. Tell me where you're at and I'll tell you honestly which of the three options fits, or whether none of them do. No pitch, no pressure."
  bg="#FFFFFF"
>
  <Fragment slot="head">
    <style>
      .bc-textlink:hover { border-color: currentColor !important; }
      @media (max-width: 820px) { [data-intro] { grid-template-columns: 1fr !important; } }
    </style>
  </Fragment>

  <div style="font-family:'Montserrat',sans-serif;background:#FFFFFF;color:#0A0A0A;min-height:100vh;">
    <SiteNav active="" />

    <section style="padding:calc(64px + clamp(40px,7vh,88px)) clamp(24px,6vw,80px) clamp(56px,8vw,104px);">
      <div style="max-width:900px;margin:0 auto;">
        <span style="display:block;font-size:11px;font-weight:600;letter-spacing:0.16em;text-transform:uppercase;color:#6B6B6B;margin-bottom:20px;">The fallback path</span>
        <h1 style="font-family:'Kensington Compressed','Arial Narrow',sans-serif;font-weight:400;font-size:clamp(44px,7vw,84px);line-height:0.95;margin:0 0 24px;max-width:760px;">Not sure which one fits? Let's talk it through.</h1>
        <div data-intro style="display:grid;grid-template-columns:1.3fr 0.7fr;gap:clamp(24px,4vw,56px);align-items:start;margin-bottom:clamp(40px,6vw,64px);">
          <p style="font-size:18px;line-height:1.65;color:#333333;margin:0;">A free 15-minute video call. You tell me where you're at, I'll tell you honestly which of the three options fits, or whether none of them do. No pitch, no pressure.</p>
          <ul style="list-style:none;margin:0;padding:0;border-top:1px solid #0A0A0A;">
            <li style="padding:14px 0;border-bottom:1px solid #E6E6E6;font-size:14px;color:#333333;display:flex;justify-content:space-between;gap:12px;"><span style="color:#6B6B6B;">Length</span><span>15 minutes</span></li>
            <li style="padding:14px 0;border-bottom:1px solid #E6E6E6;font-size:14px;color:#333333;display:flex;justify-content:space-between;gap:12px;"><span style="color:#6B6B6B;">Cost</span><span>Free</span></li>
            <li style="padding:14px 0;border-bottom:1px solid #E6E6E6;font-size:14px;color:#333333;display:flex;justify-content:space-between;gap:12px;"><span style="color:#6B6B6B;">Where</span><span>Video call</span></li>
          </ul>
        </div>

        <CalendlyEmbed url={CALENDLY.call} price="Free" note="15-minute video call" label="Pick a time for your call" />
      </div>
    </section>

    <SiteFooter />
  </div>
</BaseLayout>
