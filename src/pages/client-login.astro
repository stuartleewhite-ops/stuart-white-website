---
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteNav from '../components/SiteNav.astro';
import SiteFooter from '../components/SiteFooter.astro';
import { SITE } from '../lib/site-config';
---
<BaseLayout
  title="Client login — Stuart White"
  description="Access your personalised training, nutrition and sleep programme."
  bg="#FFFFFF"
>
  <Fragment slot="head">
    <style>
      .cl-link:hover { border-color: currentColor !important; }
      /* PT Distinction injects its own "Powered by" attribution as the portal's first child; hide it, as the live site does */
      #ptd_portal > div:first-child { display: none !important; }
    </style>
  </Fragment>

  <div style="font-family:'Montserrat',sans-serif;background:#FFFFFF;color:#0A0A0A;min-height:100vh;">
    <SiteNav active="" />

    <section style="padding:calc(64px + clamp(40px,7vh,80px)) clamp(24px,6vw,80px) clamp(56px,8vw,96px);">
      <div style="max-width:560px;margin:0 auto;">
        <span style="display:block;font-size:11px;font-weight:600;letter-spacing:0.16em;text-transform:uppercase;color:#6B6B6B;margin-bottom:20px;">Members</span>
        <h1 style="font-family:'Kensington Compressed','Arial Narrow',sans-serif;font-weight:400;font-size:clamp(44px,7vw,72px);line-height:0.95;margin:0 0 18px;">Access your online programme.</h1>
        <p style="font-size:17px;line-height:1.6;color:#6B6B6B;margin:0 0 40px;">Sign in below to view your daily plans, log sessions and track progress.</p>

        <!-- PT Distinction portal mounts here -->
        <div id="ptd_portal" style="min-height:320px;border:1px solid #E6E6E6;display:flex;align-items:center;justify-content:center;text-align:center;padding:32px;">
          <p style="font-size:13px;color:#9A9A9A;font-family:monospace;margin:0;">[ Client portal (PT Distinction) loads here ]</p>
        </div>

        <hr style="border:none;border-top:1px solid #E6E6E6;margin:36px 0 24px;" />
        <p style="font-size:13px;line-height:1.6;color:#6B6B6B;margin:0 0 12px;">First time here? You'll get your login details when your programme starts.</p>
        <p style="font-size:13px;line-height:1.6;color:#6B6B6B;margin:0;">Having trouble? <a href={`mailto:${SITE.email}`} class="cl-link" style="color:#0A0A0A;font-weight:600;border-bottom:1px solid #CCCCCC;transition:border-color .15s;">Email me here</a>.</p>
      </div>
    </section>

    <SiteFooter />
  </div>

  <script>
    // PT Distinction's own portal script mounts here and manages its own DOM
    // (including a "Powered by" attribution bar). The CSS rule above hides it
    // when it lands as the portal's first child; this observer is a fallback
    // for whichever element it actually lands in, since a third-party widget
    // gives no DOM-shape guarantee.
    (window as any).ptd_param = { apk: 'JXPMSW9C9S2009904', domain: 'https://v3portal.ptdistinction.com' };
    if (!document.getElementById('ptd-portal-js')) {
      const s = document.createElement('script');
      s.id = 'ptd-portal-js';
      s.src = 'https://v3portal.ptdistinction.com/v3/inside/integration/v1/portal.js';
      s.async = true;
      document.body.appendChild(s);
    }

    // Scoped to the whole document, not just #ptd_portal: on mobile this widget
    // sometimes renders its "Powered by" badge as a fixed bar appended directly
    // to <body>, outside the portal container.
    const hideBranding = () => {
      document.querySelectorAll('body *').forEach((el) => {
        const text = (el.textContent || '').trim();
        if (text.length < 60 && /powered by/i.test(text)) {
          (el as HTMLElement).style.setProperty('display', 'none', 'important');
        }
      });
    };
    hideBranding();
    new MutationObserver(hideBranding).observe(document.body, { childList: true, subtree: true });
    // The widget can also render well after its script loads; keep checking briefly.
    let checks = 0;
    const interval = setInterval(() => {
      hideBranding();
      if (++checks > 20) clearInterval(interval);
    }, 500);
  </script>
</BaseLayout>
