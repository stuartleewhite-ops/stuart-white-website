---
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteNav from '../components/SiteNav.astro';
import SiteFooter from '../components/SiteFooter.astro';
import CalendlyEmbed from '../components/CalendlyEmbed.astro';
import { CALENDLY } from '../lib/site-config';

const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'HealthAndBeautyBusiness',
  name: 'Stuart White Personal Training',
  description: 'One to one personal training in Whickham, Gateshead.',
  priceRange: '£35',
  areaServed: { '@type': 'Place', name: 'Whickham, Gateshead, Tyne and Wear' },
  address: { '@type': 'PostalAddress', addressLocality: 'Whickham', addressRegion: 'Tyne and Wear', addressCountry: 'GB' },
  makesOffer: { '@type': 'Offer', price: '35', priceCurrency: 'GBP', itemOffered: { '@type': 'Service', name: '1:1 Personal Training Session' } },
};
---
<BaseLayout
  title="Personal trainer in Whickham — Stuart White"
  description="One to one personal training in Whickham, Gateshead. £35 an hour at a private garage studio or a nearby gym. No block bookings, no contract. Book and pay online."
  bg="#0A0A0A"
  structuredData={structuredData}
>
  <Fragment slot="head">
    <style>
      .pt-btn-light:hover { background: #FFFFFF; }
      .pt-btn-dark:hover { background: #1A1A1A; }
      .pt-textlink:hover { border-color: currentColor !important; }
      @media (max-width: 900px) {
        [data-two] { grid-template-columns: 1fr !important; }
        [data-price] { grid-template-columns: 1fr !important; }
      }
    </style>
  </Fragment>

  <div style="font-family:'Montserrat',sans-serif;background:#FFFFFF;color:#0A0A0A;">
    <SiteNav active="/personal-training" />

    <!-- HERO -->
    <section style="position:relative;min-height:92svh;display:flex;flex-direction:column;justify-content:flex-end;padding:0 clamp(24px,6vw,80px) clamp(56px,8vh,100px);overflow:hidden;background:#0A0A0A;">
      <img src="/images/raw/who-i-am-hero.jpg" alt="Explosive box work in a garage gym, motion-blurred" style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;object-position:55% center;filter:grayscale(1) contrast(1.1) brightness(0.85);z-index:0;" fetchpriority="high" />
      <div aria-hidden="true" style="position:absolute;inset:0;z-index:1;background:linear-gradient(90deg,rgba(10,10,10,0.92) 0%,rgba(10,10,10,0.62) 46%,rgba(10,10,10,0.18) 100%);"></div>
      <div aria-hidden="true" style="position:absolute;left:0;right:0;bottom:0;height:220px;z-index:1;background:linear-gradient(to top,rgba(10,10,10,0.9),transparent);"></div>
      <div style="position:relative;z-index:2;max-width:720px;color:#FFFFFF;">
        <span style="display:block;font-size:11px;font-weight:600;letter-spacing:0.18em;text-transform:uppercase;color:#9A9A9A;margin-bottom:22px;">In person · Whickham</span>
        <h1 style="font-family:'Kensington Compressed','Arial Narrow',sans-serif;font-weight:400;font-size:clamp(52px,9vw,100px);line-height:0.95;margin:0 0 22px;">Personal training in Whickham.</h1>
        <p style="font-size:clamp(16px,1.5vw,18px);line-height:1.55;color:#E6E6E6;max-width:520px;margin:0 0 20px;">One to one sessions at my private garage studio or a gym nearby. £35 an hour, no block bookings, no contract. You book, you pay, you train.</p>
        <a href="#book" class="pt-btn-light" style="display:inline-block;background:#FFFFFF;color:#0A0A0A;border:1px solid #FFFFFF;font-size:12px;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;padding:16px 40px;border-radius:2px;transition:background .15s;">Book a session</a>
      </div>
    </section>

    <!-- THE SESSIONS -->
    <section style="padding:clamp(64px,9vw,116px) clamp(24px,6vw,80px);">
      <div style="max-width:1180px;margin:0 auto;">
        <span style="display:block;font-size:11px;font-weight:600;letter-spacing:0.16em;text-transform:uppercase;color:#6B6B6B;margin-bottom:32px;">The sessions</span>
        <div data-two style="display:grid;grid-template-columns:1fr 1fr;gap:clamp(32px,5vw,72px);align-items:start;">
          <h2 style="font-family:'Kensington Compressed','Arial Narrow',sans-serif;font-weight:400;font-size:clamp(34px,4.5vw,56px);line-height:0.98;margin:0;">Programmed, not improvised.</h2>
          <div>
            <p style="font-size:17px;line-height:1.6;color:#333333;margin:0 0 18px;">Every session is built around your goal, whether that's strength, fitness or getting moving again after years away. I write the session before you arrive; you're not paying me to make it up as we go.</p>
            <p style="font-size:17px;line-height:1.6;color:#333333;margin:0;">Technique gets coached properly. Effort gets scaled to you. You leave knowing exactly what you did and why.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- THE STUDIO (dark) -->
    <section style="background:#0A0A0A;color:#FFFFFF;padding:clamp(64px,9vw,116px) clamp(24px,6vw,80px);">
      <div style="max-width:1180px;margin:0 auto;">
        <span style="display:block;font-size:11px;font-weight:600;letter-spacing:0.16em;text-transform:uppercase;color:#9A9A9A;margin-bottom:32px;">The studio</span>
        <div data-two style="display:grid;grid-template-columns:1.1fr 0.9fr;gap:clamp(32px,5vw,72px);align-items:center;">
          <div>
            <h2 style="font-family:'Kensington Compressed','Arial Narrow',sans-serif;font-weight:400;font-size:clamp(34px,4.5vw,56px);line-height:0.98;margin:0 0 22px;">A private studio in Whickham.</h2>
            <p style="font-size:17px;line-height:1.6;color:#CCCCCC;margin:0 0 18px;max-width:500px;">I train clients at my private garage studio in Whickham, fully kitted for strength and conditioning. If you'd rather use a gym floor, a nearby gym works too.</p>
            <p style="font-size:17px;line-height:1.6;color:#CCCCCC;margin:0 0 24px;max-width:500px;">It's quiet, there's no queue for a rack, and it's just you and me. I'll share the exact address once you've booked.</p>
            <p style="font-size:13px;letter-spacing:0.04em;color:#9A9A9A;margin:0;">Whickham · Gateshead · Tyne and Wear</p>
          </div>
          <img src="/images/raw/hyrox-1.jpg" alt="Training on a rower in a garage gym, motion-blurred" style="width:100%;aspect-ratio:3/4;object-fit:cover;filter:grayscale(1) contrast(1.08) brightness(0.9);display:block;" loading="lazy" />
        </div>
      </div>
    </section>

    <!-- PRICING -->
    <section style="padding:clamp(64px,9vw,116px) clamp(24px,6vw,80px);">
      <div style="max-width:1180px;margin:0 auto;">
        <span style="display:block;font-size:11px;font-weight:600;letter-spacing:0.16em;text-transform:uppercase;color:#6B6B6B;margin-bottom:36px;">Pricing</span>
        <div data-price style="display:grid;grid-template-columns:0.8fr 1.2fr;gap:clamp(24px,4vw,56px);align-items:center;">
          <div>
            <div style="display:flex;align-items:baseline;gap:10px;"><span style="font-family:'Kensington Compressed','Arial Narrow',sans-serif;font-size:clamp(72px,9vw,120px);line-height:0.9;">£35</span><span style="font-size:16px;color:#6B6B6B;">an hour</span></div>
          </div>
          <ul style="list-style:none;margin:0;padding:0;display:flex;flex-direction:column;gap:0;border-top:1px solid #0A0A0A;">
            <li style="padding:20px 0;border-bottom:1px solid #E6E6E6;font-size:16px;color:#333333;">Pay when you book. No block bookings, no contract.</li>
            <li style="padding:20px 0;border-bottom:1px solid #E6E6E6;font-size:16px;color:#333333;">Cancel or move a session up to 24 hours before, at no charge.</li>
            <li style="padding:20px 0;border-bottom:1px solid #E6E6E6;font-size:16px;color:#333333;">Exact studio location shared as soon as you've booked.</li>
          </ul>
        </div>
      </div>
    </section>

    <!-- BOOKING -->
    <section id="book" style="background:#F5F5F5;padding:clamp(56px,8vw,104px) clamp(24px,6vw,80px);scroll-margin-top:64px;">
      <div style="max-width:820px;margin:0 auto;">
        <span style="display:block;font-size:11px;font-weight:600;letter-spacing:0.16em;text-transform:uppercase;color:#6B6B6B;margin-bottom:18px;">Book a session</span>
        <h2 style="font-family:'Kensington Compressed','Arial Narrow',sans-serif;font-weight:400;font-size:clamp(32px,4.5vw,52px);line-height:1;margin:0 0 12px;">Pick a time and pay. That's it.</h2>
        <p style="font-size:16px;line-height:1.55;color:#6B6B6B;max-width:520px;margin:0 0 36px;">Choose a slot below and pay the £35 at booking. You'll get a confirmation with the studio address and a short health and goals form to fill in before your first session.</p>
        <CalendlyEmbed url={CALENDLY.pt} price="£35" note="an hour" label="Pick a personal training slot" />
        <p style="font-size:14px;line-height:1.6;color:#6B6B6B;margin:28px 0 0;">Not sure it's right for you yet? <a href="/book-a-call" class="pt-textlink" style="color:#0A0A0A;font-weight:600;border-bottom:1px solid #CCCCCC;transition:border-color .15s;">Book a free 15-minute call</a> first.</p>
      </div>
    </section>

    <SiteFooter />
  </div>
</BaseLayout>
