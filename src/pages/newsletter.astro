---
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteNav from '../components/SiteNav.astro';
import SiteFooter from '../components/SiteFooter.astro';
---
<BaseLayout
  title="Heavy Lifting newsletter — Stuart White"
  description="A weekly five-minute read on training, nutrition and recovery. Actionable from the first line. No noise."
  bg="#FFFFFF"
>
  <Fragment slot="head">
    <style>
      .nl-submit:hover { background: #1A1A1A; }
      .nl-input:focus { border-color: #0A0A0A !important; }
      @media (max-width: 820px) {
        [data-nl-grid] { grid-template-columns: 1fr !important; }
        [data-nl-img] { order: 2; padding: 8px 24px 56px !important; }
        [data-nl-form] { order: 1; }
        [data-nl-row] { flex-direction: column !important; }
        .nl-input { border-right: 1px solid #CCCCCC !important; border-radius: 2px !important; }
        .nl-submit { border-radius: 2px !important; }
      }
      .nl-done { display: none; }
      .nl-done.visible { display: block; }
      .nl-form.hidden { display: none; }
      .nl-error { display: none; }
      .nl-error.visible { display: block; }
    </style>
  </Fragment>

  <div style="font-family:'Montserrat',sans-serif;background:#FFFFFF;color:#0A0A0A;min-height:100vh;">
    <SiteNav active="" />

    <section data-nl-grid style="display:grid;grid-template-columns:1fr 1fr;padding-top:64px;min-height:100vh;">
      <div data-nl-img style="display:flex;align-items:center;justify-content:flex-end;padding:60px 0 60px clamp(24px,5vw,60px);background:#F5F5F5;">
        <img src="/images/heavy-lifting-phone-mockup.png" alt="The Heavy Lifting newsletter on a phone" style="max-height:560px;max-width:100%;object-fit:contain;display:block;" fetchpriority="high" />
      </div>
      <div data-nl-form style="display:flex;flex-direction:column;justify-content:center;padding:clamp(48px,6vw,80px) clamp(24px,5vw,72px);">
        <span style="font-size:11px;font-weight:600;letter-spacing:0.16em;text-transform:uppercase;color:#6B6B6B;margin-bottom:22px;">The Heavy Lifting newsletter</span>
        <h1 style="font-family:'Kensington Compressed','Arial Narrow',sans-serif;font-weight:400;font-size:clamp(40px,4.6vw,64px);line-height:0.97;margin:0 0 26px;">Performance, without the noise.</h1>
        <p style="font-size:16px;line-height:1.7;color:#6B6B6B;max-width:440px;margin:0 0 44px;">Every week I do the <strong style="color:#0A0A0A;font-weight:600;">Heavy Lifting</strong> so you don't have to. A five-minute read on training, nutrition and recovery. Actionable from the first line.</p>

        <div class="nl-done" id="nl-done" style="max-width:440px;">
          <div style="font-family:'Kensington Compressed','Arial Narrow',sans-serif;font-size:clamp(32px,3.5vw,48px);line-height:0.97;margin-bottom:12px;">You're in.</div>
          <p style="font-size:15px;color:#6B6B6B;line-height:1.65;margin:0;">First edition lands in your inbox shortly. No noise, just the essentials.</p>
        </div>

        <form id="nl-form" class="nl-form" style="max-width:440px;">
          <label for="nl-email" style="display:block;font-size:10px;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;color:#6B6B6B;margin-bottom:10px;">Enter your email address</label>
          <div data-nl-row style="display:flex;align-items:stretch;">
            <input id="nl-email" type="email" name="email" required placeholder="you@email.com" autocomplete="email" class="nl-input" style="flex:1;font-size:14px;color:#0A0A0A;background:#FFFFFF;border:1px solid #CCCCCC;border-right:none;border-radius:2px 0 0 2px;padding:14px 16px;outline:none;transition:border-color .15s;" />
            <button type="submit" class="nl-submit" id="nl-submit-btn" style="font-size:11px;font-weight:600;letter-spacing:0.08em;text-transform:uppercase;color:#FFFFFF;background:#0A0A0A;border:1px solid #0A0A0A;border-radius:0 2px 2px 0;padding:14px 28px;cursor:pointer;white-space:nowrap;transition:background .15s;">Try it</button>
          </div>
          <p style="font-size:11px;color:#9A9A9A;margin:14px 0 0;">No spam, ever.</p>
          <p class="nl-error" id="nl-error" style="font-size:12px;color:#C0392B;margin:10px 0 0;"></p>
        </form>
      </div>
    </section>

    <SiteFooter />
  </div>

  <script>
    (function () {
      // Same Mailchimp audience the live site posts to.
      const MAILCHIMP_BASE = 'https://gmail.us12.list-manage.com/subscribe/post-json?u=b9db7b8b042000659f8e153a5&id=7fe49b6645&f_id=006d48e0f0&c=_mcNlCb';

      const form = document.getElementById('nl-form') as HTMLFormElement | null;
      const done = document.getElementById('nl-done');
      const errorEl = document.getElementById('nl-error');
      const submitBtn = document.getElementById('nl-submit-btn') as HTMLButtonElement | null;
      const emailInput = document.getElementById('nl-email') as HTMLInputElement | null;
      if (!form || !done || !errorEl || !submitBtn || !emailInput) return;

      function setError(msg: string) {
        errorEl!.textContent = msg;
        errorEl!.classList.toggle('visible', !!msg);
      }

      form.addEventListener('submit', (e) => {
        e.preventDefault();
        const email = emailInput.value.trim();
        if (!email || !/^[^@\s]+@[^@\s]+\.[^@\s]+$/.test(email)) {
          setError('Please enter a valid email address.');
          return;
        }
        setError('');
        submitBtn.disabled = true;
        submitBtn.textContent = 'Subscribing…';

        (window as any)._mcNlCb = (data: any) => {
          const already = data && data.result === 'error' && data.msg && String(data.msg).toLowerCase().includes('already subscribed');
          submitBtn.disabled = false;
          submitBtn.textContent = 'Try it';
          if (!data || data.result === 'success' || already) {
            form.classList.add('hidden');
            done.classList.add('visible');
          } else {
            setError((data.msg || 'Something went wrong. Please try again.').replace(/<[^>]+>/g, '').replace(/^\d+ - /, ''));
          }
        };

        const old = document.getElementById('mc-nl-script');
        if (old) old.remove();
        const s = document.createElement('script');
        s.id = 'mc-nl-script';
        s.src = MAILCHIMP_BASE + '&EMAIL=' + encodeURIComponent(email);
        s.onerror = () => {
          submitBtn.disabled = false;
          submitBtn.textContent = 'Try it';
          setError('Could not reach the server. Please try again.');
        };
        document.head.appendChild(s);
      });
    })();
  </script>
</BaseLayout>
