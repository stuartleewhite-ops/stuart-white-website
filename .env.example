# Stripe secret key, used server-side only by netlify/functions/create-subscription.js.
# Never exposed to the browser. Set this in the Netlify dashboard (Site
# configuration -> Environment variables), not in a committed .env file.
# Use a live secret key ("sk_live_...") in production, a test secret key
# ("sk_test_...") when running `netlify dev` locally against Stripe test mode.
STRIPE_SECRET_KEY=
